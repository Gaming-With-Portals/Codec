<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
  xmlns:views="using:Codec.Avalonia.Views"
  x:Class="Codec.Avalonia.Views.AudioPreviewWindow"
  x:DataType="views:AudioPreviewWindow+ViewModel"
  Icon="/Assets/avalonia-logo.ico"
  WindowStartupLocation="CenterOwner"
  Title="Audio Preview"
  Width="380"
  Height="150">
  <Grid ColumnDefinitions="20,1*,*,1*,20" RowDefinitions="*,*">
    <ProgressBar Grid.Column="1" Grid.ColumnSpan="3" VerticalAlignment="Bottom" Height="20" Value="{Binding Progress}" />
    <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Top" Orientation="Horizontal">
      <Button Command="{Binding Stop}" IsEnabled="{Binding CanStop}" Content="{iconPacks:FontAwesome Kind=StopSolid}" />
      <Button Command="{Binding PlayPause}">
        <iconPacks:PackIconFontAwesome Kind="{Binding PlayPauseIcon}"/>
      </Button>
    </StackPanel>
  </Grid>
</Window>
