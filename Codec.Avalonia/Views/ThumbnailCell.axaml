<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Codec.Avalonia.ViewModels"
             x:Class="Codec.Avalonia.Views.ThumbnailCell"
             x:DataType="vm:ThumbnailItemViewModel"
             Width="96" Height="96">
  <Grid>
    <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
  </Grid>
</UserControl>
