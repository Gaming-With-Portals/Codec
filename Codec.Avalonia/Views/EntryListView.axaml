<UserControl
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
  xmlns:models="using:Codec.Avalonia.Models"
  xmlns:conv="using:Codec.Avalonia.Converters"
  xmlns:vm="using:Codec.Avalonia.ViewModels"
  xmlns:views="using:Codec.Avalonia.Views"
  x:Class="Codec.Avalonia.Views.EntryListView"
  x:DataType="vm:EntryListViewModel">
  <UserControl.Resources>
    <conv:FileIconEntryConverter x:Key="FileIconEntryConverter" />
    <conv:ViewModeConverter x:Key="ViewModeConverter" />
  </UserControl.Resources>
  <Panel>
    <ListBox
      ItemsSource="{Binding Entries}"
      SelectionMode="Multiple"
      SelectedItems="{Binding SelectedEntries}"
      IsVisible="{Binding CurrentViewMode, Converter={StaticResource ViewModeConverter}, ConverterParameter=NotImagePreview}"
      DoubleTapped="ListBox_DoubleTapped">
      <ListBox.KeyBindings>
        <KeyBinding Command="{Binding ActivateSelectedItem}" Gesture="Enter" />
      </ListBox.KeyBindings>
      <ListBox.ItemTemplate>
        <DataTemplate DataType="models:EntryItem">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <iconPacks:PackIconFontAwesome
              Kind="{Binding EntryType, Converter={StaticResource FileIconEntryConverter}}"
              Width="{Binding $parent[TemplatedControl].FontSize}"
              Height="{Binding $parent[TemplatedControl].FontSize}"
              Margin="2" />
            <TextBlock Text="{Binding DisplayName}" />
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    <ScrollViewer IsVisible="{Binding CurrentViewMode, Converter={StaticResource ViewModeConverter}, ConverterParameter={x:Static models:ViewMode.ImagePreview}}">
      <ItemsRepeater ItemsSource="{Binding Thumbnails}">
        <ItemsRepeater.Layout>
          <UniformGridLayout MinItemWidth="96" MinItemHeight="96" ItemsStretch="Fill" />
        </ItemsRepeater.Layout>
        <ItemsRepeater.ItemTemplate>
          <DataTemplate DataType="vm:ThumbnailItemViewModel">
            <views:ThumbnailCell />
          </DataTemplate>
        </ItemsRepeater.ItemTemplate>
      </ItemsRepeater>
    </ScrollViewer>
  </Panel>
</UserControl>
