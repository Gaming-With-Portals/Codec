<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
  xmlns:conv="using:Codec.Avalonia.Converters"
  xmlns:models="using:Codec.Avalonia.Models"
  xmlns:vm="using:Codec.Avalonia.ViewModels"
  xmlns:views="using:Codec.Avalonia.Views"
  x:Class="Codec.Avalonia.Views.BrowserWindow"
  x:DataType="vm:BrowserViewModel"
  Icon="/Assets/avalonia-logo.ico"
  Title="Codec">
  <Design.DataContext>
    <vm:BrowserViewModel/>
  </Design.DataContext>
  <Window.Resources>
    <conv:ViewModeConverter x:Key="ViewModeConverter" />
  </Window.Resources>
  <DockPanel>
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
      <Button Content="{iconPacks:FontAwesome Kind=FloppyDiskSolid}" IsEnabled="{Binding List.CanSave}" Command="{Binding List.SaveCommand}" CommandParameter="{Binding $parent[Window]}" />
      <DropDownButton Content="{iconPacks:FontAwesome Kind=GearSolid}" VerticalAlignment="Center">
        <DropDownButton.Flyout>
          <MenuFlyout Placement="BottomEdgeAlignedLeft">
            <MenuItem
              Header="List"
              GroupName="TopViewMode"
              ToggleType="Radio"
              IsChecked="{Binding List.CurrentViewMode, Mode=TwoWay, Converter={StaticResource ViewModeConverter}, ConverterParameter={x:Static models:ViewMode.List}}"/>
            <MenuItem
              Header="Small Icons"
              GroupName="TopViewMode"
              ToggleType="Radio"
              IsChecked="{Binding List.CurrentViewMode, Mode=TwoWay, Converter={StaticResource ViewModeConverter}, ConverterParameter={x:Static models:ViewMode.SmallIcons}}"/>
            <MenuItem
              Header="Image Preview"
              GroupName="TopViewMode"
              ToggleType="Radio"
              IsChecked="{Binding List.CurrentViewMode, Mode=TwoWay, Converter={StaticResource ViewModeConverter}, ConverterParameter={x:Static models:ViewMode.ImagePreview}}"/>
          </MenuFlyout>
        </DropDownButton.Flyout>
      </DropDownButton>
    </StackPanel>
    <DockPanel DockPanel.Dock="Top" Margin="4">
      <TextBlock DockPanel.Dock="Left" Text="Path:" VerticalAlignment="Center" Margin="0,0,4,0" />
      <TextBox Text="{Binding CurrentPath}">
        <TextBox.KeyBindings>
          <KeyBinding Gesture="Return" Command="{Binding CommitPathBoxCommand}" />
        </TextBox.KeyBindings>
      </TextBox>
    </DockPanel>
    <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Margin="4,2" />
    <Grid ColumnDefinitions="1*,4,2*">
      <views:FileTreeView Grid.Column="0" DataContext="{Binding Tree}" />
      <GridSplitter Grid.Column="1" ResizeDirection="Columns" />
      <views:EntryListView Grid.Column="2" DataContext="{Binding List}" />
    </Grid>
  </DockPanel>
</Window>
