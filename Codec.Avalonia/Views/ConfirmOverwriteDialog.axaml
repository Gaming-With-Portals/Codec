<Window
  xmlns="https://github.com/avaloniaui"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:iconPacks="https://github.com/MahApps/IconPacks.Avalonia"
  x:Class="Codec.Avalonia.Views.ConfirmOverwriteDialog"
  Icon="/Assets/avalonia-logo.ico"
  Title="Confirm Overwrite"
  WindowStartupLocation="CenterOwner"
  CanResize="False"
  Width="320"
  Height="150">
  <Grid Margin="20" ColumnDefinitions="Auto, *" RowDefinitions="*, Auto" Background="Transparent">
    <iconPacks:PackIconFontAwesome Grid.Column="0" Grid.Row="0" Kind="ExclamationSolid" Width="32" Height="32" Foreground="Orange" VerticalAlignment="Center" Margin="0,0,20,0"/>
    <TextBlock Grid.Column="1" Grid.Row="0" Text="The destination folder already contains files with the same name. Overwrite?" TextWrapping="Wrap" VerticalAlignment="Center"/>
    <StackPanel Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,15,0,0">
      <Button Content="Yes" Click="OnYesClick" Width="75" HotKey="Enter"/>
      <Button Content="No" Click="OnNoClick" Width="75" HotKey="Escape"/>
    </StackPanel>
  </Grid>
</Window>
